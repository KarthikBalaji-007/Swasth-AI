# === Swasth AI Environment Configuration ===

# MongoDB connection string
# Local: mongodb://localhost:27017/swasthai
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/swasthai
MONGODB_URI=Your_URI_Here

# Google Gemini API Key (optional - app works without it using fallback messages)
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=Your_API-Key_Here

# JWT Secret for dashboard authentication
JWT_SECRET=swasthai_jwt_secret_change_in_production

# Server port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
